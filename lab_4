
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>JavaScript задания</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 800px;
            margin: 30px auto;
            padding: 0 20px;
            background: #f0f2f5;
        }
        h1 {
            color: #2c3e50;
            text-align: center;
            font-size: 28px;
        }
        .task {
            background: white;
            border-radius: 12px;
            padding: 18px 22px;
            margin-bottom: 20px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.1);
            border-left: 5px solid #4a90e2;
        }
        .task h3 {
            margin: 0 0 8px 0;
            color: #2c3e50;
            font-size: 20px;
        }
        .task p {
            margin: 8px 0;
            color: #555;
            font-size: 14px;
        }
        button {
            background: #4a90e2;
            color: white;
            border: none;
            padding: 8px 18px;
            border-radius: 20px;
            cursor: pointer;
            font-size: 14px;
            margin-top: 8px;
            margin-right: 8px;
        }
        button:hover {
            background: #357abd;
        }
        .result {
            background: #f8f9fa;
            padding: 10px 14px;
            border-radius: 8px;
            margin-top: 12px;
            font-size: 14px;
            color: #2c3e50;
            border: 1px solid #e0e0e0;
        }
        input {
            padding: 6px 12px;
            border-radius: 20px;
            border: 1px solid #ccc;
            width: 90px;
            margin-top: 5px;
        }
        .code {
            font-family: monospace;
            background: #eef2f7;
            padding: 6px 10px;
            border-radius: 8px;
            font-size: 13px;
            margin: 8px 0;
        }
    </style>
</head>
<body>

<h1>Задания по JavaScript</h1>

<!-- Задание 1 -->
<div class="task">
    <h3>1. Переменные admin и name</h3>
    <div class="code">let name = "Джон"; let admin = name; alert(admin);</div>
    <button onclick="task1()">Запустить</button>
    <div class="result" id="result1">Нажмите кнопку</div>
</div>

<!-- Задание 2 -->
<div class="task">
    <h3>2. Исправить сложение</h3>
    <p>Ошибка: prompt возвращает строки, нужно преобразовать в числа</p>
    <div class="code">let a = prompt(); let b = prompt(); alert(Number(a)+Number(b));</div>
    <button onclick="task2()">Запустить сложение</button>
    <div class="result" id="result2">Нажмите кнопку</div>
</div>

<!-- Задание 3 -->
<div class="task">
    <h3>3. Чётные числа от 2 до 10</h3>
    <div class="code">for (let i=2; i<=10; i+=2) alert(i);</div>
    <button onclick="task3()">Показать чётные числа</button>
    <div class="result" id="result3">Нажмите кнопку</div>
</div>

<!-- Задание 4 -->
<div class="task">
    <h3>4. Замена for на while</h3>
    <div class="code">let i=0; while(i<3) { alert('number ' + i + '!'); i++; }</div>
    <button onclick="task4()">Выполнить while</button>
    <div class="result" id="result4">Нажмите кнопку</div>
</div>

<!-- Задание 5 -->
<div class="task">
    <h3>5. Повторять пока ввод неверен (число > 100)</h3>
    <p>Вводите числа, пока не введёте больше 100 или не нажмёте Отмена</p>
    <button onclick="task5()">Проверить ввод</button>
    <div class="result" id="result5">Нажмите кнопку</div>
</div>

<!-- Задание 6 -->
<div class="task">
    <h3>6. Простые числа от 2 до n</h3>
    <p>Введите n: <input type="number" id="nValue" value="10" min="2" step="1"></p>
    <button onclick="task6()">Найти простые числа</button>
    <div class="result" id="result6">Нажмите кнопку</div>
</div>

<script>
    // Задание 1
    function task1() {
        let name = "Джон";
        let admin = name;
        alert(admin);
        document.getElementById("result1").innerHTML = "Выполнено: alert показал 'Джон'";
    }

    // Задание 2 - исправленное сложение
    function task2() {
        let a = prompt("Первое число?", "1");
        let b = prompt("Второе число?", "2");
        let sum = Number(a) + Number(b);
        if (isNaN(sum)) {
            alert("Ошибка: введите числа");
            document.getElementById("result2").innerHTML = "Ошибка: нужно ввести числа";
        } else {
            alert("Сумма: " + sum);
            document.getElementById("result2").innerHTML = a + " + " + b + " = " + sum;
        }
    }

    // Задание 3 - чётные числа 2-10
    function task3() {
        let nums = [];
        for (let i = 2; i <= 10; i += 2) {
            alert(i);
            nums.push(i);
        }
        document.getElementById("result3").innerHTML = "Чётные числа: " + nums.join(", ") + " (выведены в alert)";
    }

    // Задание 4 - замена for на while
    function task4() {
        let i = 0;
        let msgs = [];
        while (i < 3) {
            let msg = "number " + i + "!";
            alert(msg);
            msgs.push(msg);
            i++;
        }
        document.getElementById("result4").innerHTML = "Выведены alert: " + msgs.join(", ");
    }

    // Задание 5 - повторять пока число > 100 или отмена
    function task5() {
        let attempts = 0;
        while (true) {
            let input = prompt("Введите число больше 100 (или Отмена для выхода)", "");
            attempts++;
            
            if (input === null) {
                alert("Отмена");
                document.getElementById("result5").innerHTML = "Отмена. Попыток: " + attempts;
                break;
            }
            
            let num = Number(input);
            if (isNaN(num)) {
                alert("Это не число, попробуйте ещё");
                continue;
            }
            
            if (num > 100) {
                alert("Верно! " + num + " > 100");
                document.getElementById("result5").innerHTML = "Успех! Число " + num + " > 100. Попыток: " + attempts;
                break;
            } else {
                alert("Число " + num + " не больше 100. Повторите");
            }
        }
    }

    // Задание 6 - простые числа
    function isPrime(num) {
        if (num < 2) return false;
        if (num === 2) return true;
        if (num % 2 === 0) return false;
        for (let d = 3; d * d <= num; d += 2) {
            if (num % d === 0) return false;
        }
        return true;
    }

    function task6() {
        let n = parseInt(document.getElementById("nValue").value, 10);
        if (isNaN(n) || n < 2) {
            alert("Ошибка: n должно быть >= 2");
            document.getElementById("result6").innerHTML = "Ошибка: введите число >= 2";
            return;
        }
        
        let primes = [];
        for (let i = 2; i <= n; i++) {
            if (isPrime(i)) primes.push(i);
        }
        
        if (primes.length === 0) {
            document.getElementById("result6").innerHTML = "Простых чисел от 2 до " + n + " нет";
        } else {
            alert("Простые числа: " + primes.join(", "));
            document.getElementById("result6").innerHTML = "Простые числа от 2 до " + n + ": " + primes.join(", ");
        }
    }
</script>

</body>
</html>
